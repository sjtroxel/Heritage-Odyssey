{
  "name": "heritage-odyssey",
  "version": "1.0.0",
  "private": true,
  "description": "Family migration and history intelligence platform",
  "type": "module",
  "workspaces": [
    "server",
    "client",
    "shared",
    "scripts"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "coverage": "npm run coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "concurrently -n \"server,client\" -c \"blue,green\" \"npm run dev -w server\" \"npm run dev -w client\"",
    "eval": "cd evaluation && venv/bin/python main.py",
    "eval:dashboard": "cd evaluation && venv/bin/python main.py --dashboard",
    "eval:trace": "EVAL_MODE=true npm run dev",
    "test": "npm test --workspaces --if-present",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
