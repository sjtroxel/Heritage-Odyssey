# Server — General
PORT=3000 # Express listen port (Railway sets this automatically in production)
NODE_ENV=development # development | production

# Database & Auth (Phase 2)
DATABASE_URL=postgresql://user:password@host/dbname # Neon PostgreSQL connection string (pooled URL from Neon dashboard)
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_secret

# AI Services
OPENAI_API_KEY=sk-replace_with_your_openai_key # Used for GPT-4o (agent swarm), GPT-4o-mini (synthesizer), Whisper STT, and text-embedding-3-small
PINECONE_API_KEY=replace_with_your_pinecone_key # From Pinecone console
PINECONE_ENVIRONMENT=us-east-1-aws # Your Pinecone index region/environment
PINECONE_INDEX=heritage-odyssey # Name of your Pinecone serverless index (1536 dims, cosine metric)
ELEVENLABS_API_KEY=replace_with_your_elevenlabs_key # From ElevenLabs dashboard
ELEVENLABS_VOICE_ID=replace_with_voice_id # Voice ID for the narrator — find in ElevenLabs voice library

# Frontend (Vite — prefix with VITE_ to expose to client bundle)
VITE_API_URL=http://localhost:3000 # Backend URL; set to Railway public URL in production

# CORS (Server)
CORS_ORIGIN=http://localhost:5173 # Allowed frontend origin; set to Vercel public URL in production

# Dev / Eval tooling (leave unset in production)
EVAL_MODE=false # Set to true to enable LangGraph trace logging to evaluation/traces/
LANGCHAIN_TRACING_V2=false # Set to true only with a configured LANGCHAIN_API_KEY for LangSmith — never enable in production without it
LANGCHAIN_API_KEY=replace_with_langsmith_key # LangSmith API key — only needed if LANGCHAIN_TRACING_V2=true
